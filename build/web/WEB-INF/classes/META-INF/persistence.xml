<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence           http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
  <persistence-unit name="ProyectoPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <class>logica.Categoria</class>
    <class>logica.Cliente</class>
    <class>logica.Correocliente</class>
    <class>logica.Detallepedido</class>
    <class>logica.Envio</class>
    <class>logica.Marca</class>
    <class>logica.Pago</class>
    <class>logica.Pedido</class>
    <class>logica.Permiso</class>
    <class>logica.Producto</class>
    <class>logica.Rol</class>
    <class>logica.Rolpermiso</class>
    <class>logica.Telefonocliente</class>
    <class>logica.Usuario</class>
    <exclude-unlisted-classes>false</exclude-unlisted-classes>
    <properties>
      <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/Perfumeria_andreylpz?serverTimezone=UTC"/>
      <property name="javax.persistence.jdbc.user" value="root"/>
      <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="javax.persistence.jdbc.password" value="123456789"/>
      <property name="javax.persistence.schema-generation.database.action" value="create"/>
    </properties>
  </persistence-unit>
</persistence>
